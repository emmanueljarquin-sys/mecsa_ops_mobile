	<string>Necesitamos acceso a la cámara para tomar fotos de evidencia de las tareas realizadas.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Necesitamos acceso a tu galería para subir fotos de evidencia.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Necesitamos acceso al micrófono si decides grabar videos de evidencia.</string>
	<key>NSMotionUsageDescription</key>
	<string>Necesitamos acceso a los sensores de movimiento para optimizar el consumo de batería durante el rastreo GPS.</string>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>https</string>
		<string>http</string>
		<string>tel</string>
		<string>mailto</string>
		<string>comgooglemaps</string>
		<string>baidumap</string>
		<string>iosamap</string>
		<string>waze</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
